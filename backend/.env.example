# Relative paths are resolved from the repository root.
DATABASE_PATH=./data/inventory.sqlite
PHOTO_PATH=./photos
BACKUP_PATH=./backups
SESSION_SECRET=change-me-before-real-use
LOCAL_SERVER_ADDRESS=http://0.0.0.0:3000
ENABLE_DEBUG_BULK_DELETE=false

# Used only when the users table is empty to create the first private account.
BOOTSTRAP_USERNAME=owner
BOOTSTRAP_PASSWORD=change-this-before-first-login
