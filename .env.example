# Example environment variables for VirtualTotes
# Copy this file to `backend/.env` (or copy values into that file) and edit before running.

# Relative paths are resolved from the repository root in the server config
DATABASE_PATH=./data/inventory.sqlite
PHOTO_PATH=./photos

# Replace with a strong secret for any real deployment
SESSION_SECRET=change-me-before-real-use

# Server bind address (scheme://host:port)
LOCAL_SERVER_ADDRESS=http://0.0.0.0:3000

# Optional bootstrap account that will be created if the users table is empty
BOOTSTRAP_USERNAME=owner
BOOTSTRAP_PASSWORD=change-this-before-first-login
